{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "opener:default",
    "fs:default",
    "shell:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://**"
        },
        {
          "url": "http://127.0.0.1:17871"
        },
        {
          "url": "http://127.0.0.1:17872"
        }
      ]
    },
    "notification:default"
  ]
}